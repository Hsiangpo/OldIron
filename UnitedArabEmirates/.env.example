# 阿联酋站点默认走协议采集，外网默认通过 7897 代理
HTTP_PROXY=http://127.0.0.1:7897
HTTPS_PROXY=http://127.0.0.1:7897

# LLM 只用于官网代表人提取，不用于邮箱提取
LLM_API_KEY=
LLM_BASE_URL=https://gpt-agent.cc/v1
LLM_MODEL=claude-sonnet-4-6
LLM_REASONING_EFFORT=
LLM_API_STYLE=chat
LLM_TIMEOUT_SECONDS=120

# HiDubai 协议接口必需请求头
HIDUBAI_GUEST_USER_ID=cc60d8b7-4d35-4980-93ed-4dbb9b4c04fa

# DubaiBizDirectory 浏览器模式
DUBAIBIZDIRECTORY_BROWSER_HEADLESS=0
DUBAIBIZDIRECTORY_BROWSER_TIMEOUT_SECONDS=30
