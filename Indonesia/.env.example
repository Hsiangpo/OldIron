# GAPENSI 为公开站点，无需额外凭据。
# 第二站 indonesiayp 联动 AHU + Snov 需要以下配置：

# Snov API 凭据（用于官网域名补全邮箱）
SNOV_CLIENT_ID=
SNOV_CLIENT_SECRET=

# 2Captcha API KEY（用于 AHU reCAPTCHA v3）
TWO_CAPTCHA_API_KEY=

# AHU 请求节奏（可选，默认值见右侧）
AHU_REQUEST_DELAY=1.5
AHU_TIMEOUT=45
AHU_MAX_RETRIES=3
AHU_RETRY_BACKOFF=2
AHU_RATE_LIMIT_WAIT=8
AHU_RATE_LIMIT_COOLDOWN=300

# AHU 代理配置（可选）
# 模式：off / static / pool
AHU_PROXY_MODE=off

# static 模式：单代理 URL（支持 http://user:pass@host:port 或 socks5://...）
# AHU 直连本地出海代理时可填：socks5h://127.0.0.1:7897
AHU_PROXY_URL=

# pool 模式：代理列表（支持逗号/分号/换行分隔）
# 条目格式支持：
# 1) host:port
# 2) host:port:username:password
# 3) http://user:pass@host:port
AHU_PROXY_LIST=

# pool 模式：代理列表文件（每行一个条目，支持 # 注释）
AHU_PROXY_LIST_FILE=

# 默认代理协议（当条目未写协议时生效）：http / https / socks5
AHU_PROXY_DEFAULT_SCHEME=http

# 前置代理（可选）：用于“本地 -> 前置代理 -> Cliproxy”链路
# 示例：socks5h://127.0.0.1:7897
AHU_PRE_PROXY_URL=

# 失败熔断冷却（秒）
AHU_PROXY_COOLDOWN_SECONDS=30
AHU_PROXY_MAX_COOLDOWN_SECONDS=300

# 代理请求与熔断（可选）
# 代理单次请求超时（秒），用于避免代理故障时长期卡住
AHU_PROXY_TIMEOUT=8
# 代理连续异常达到阈值后自动禁用代理池并降级直连（默认 3）
AHU_PROXY_DISABLE_THRESHOLD=3
# 启动健康检查：全部代理不可用时自动降级直连
AHU_PROXY_HEALTHCHECK_ENABLED=true
AHU_PROXY_HEALTHCHECK_TIMEOUT=5
# 启动时最多探测多少个代理节点（默认 3，避免坏池子拖慢启动）
AHU_PROXY_HEALTHCHECK_PROBES=3
AHU_PROXY_HEALTHCHECK_URL=http://httpbin.org/ip

# Cliproxy 账号模式可选：自动附加 -sid-随机串-t-分钟，触发更快切换 IP
AHU_PROXY_SID_ENABLED=false
AHU_PROXY_SID_TTL_MINUTES=3
AHU_PROXY_SID_LENGTH=8

# 本地桥接代理（可选）：用于“爬虫 -> 本地桥接器 -> 7897 -> Cliproxy -> 目标站”
# 先启动：python run.py proxy-bridge --prefix CHAIN
# 再让业务请求走本地桥接器，例如：AHU_PROXY_MODE=static + AHU_PROXY_URL=http://127.0.0.1:8899
CHAIN_PROXY_MODE=off
CHAIN_PROXY_LIST=
CHAIN_PROXY_LIST_FILE=
CHAIN_PROXY_DEFAULT_SCHEME=http
CHAIN_PRE_PROXY_URL=socks5h://127.0.0.1:7897
CHAIN_LISTEN_HOST=127.0.0.1
CHAIN_LISTEN_PORT=8899
CHAIN_CONNECT_TIMEOUT=15
CHAIN_IDLE_TIMEOUT=90
# IndonesiaYP Cloudflare 挑战通过后的 Cookie（至少包含 CAKEPHP 和 cf_clearance）
# 示例：IYP_COOKIE=CAKEPHP=xxx; cf_clearance=yyy
IYP_COOKIE=

# IndonesiaYP 请求 UA（建议与浏览器一致）
IYP_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/145.0.0.0 Safari/537.36

# IndonesiaYP 可选代理（用于详情请求，如需走本地代理可填 socks5h://127.0.0.1:7897）
IYP_PROXY_URL=

# IndonesiaYP 请求参数
IYP_TIMEOUT=30
IYP_MAX_RETRIES=3
IYP_RETRY_BACKOFF=2
IYP_403_WAIT=6
# 多个指纹逗号分隔，403 时会自动轮换并重建会话
IYP_IMPERSONATES=chrome110,chrome124,chrome136



