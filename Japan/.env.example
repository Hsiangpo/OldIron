# Japan 新框架
#
# 运行命令：
#   cd Japan
#   python run.py bizmaps all      # 顺序执行 P1→P2→P3
#   python run.py bizmaps list     # 只跑 P1 列表页采集
#   python run.py bizmaps gmap     # 只跑 P2 GMap 官网补全
#   python run.py bizmaps email    # 只跑 P3 邮箱提取
#
# 交付命令：
#   cd ..
#   python product.py Japan day1
#
# Japan 多机同日交付辅助：
#   JAPAN_DELIVERY_SITES=openwork,mynavi
#     只为当前机器负责的站点生成 csv/keys
#   JAPAN_DELIVERY_SUMMARY_ONLY=1
#     汇总机只重建 summary.json，不重打站点文件

# 代理（日本站点需要翻墙）
HTTP_PROXY=http://127.0.0.1:7897
GOOGLE_MAPS_PROXY_URL=socks5h://127.0.0.1:7897

# 2Captcha（OpenWork 图片验证码自动识别）
TWOCAPTCHA_API_KEY=

# LLM 配置（Pipeline 3 需要）
LLM_API_KEY=
LLM_BASE_URL=https://cc.gpteam.top/v1
LLM_MODEL=gpt-5.1-codex-mini
LLM_REASONING_EFFORT=medium
LLM_API_STYLE=auto
LLM_TIMEOUT_SECONDS=120

# Protocol+LLM 参数
FIRECRAWL_PREFILTER_LIMIT=40
FIRECRAWL_LLM_PICK_COUNT=8
FIRECRAWL_EXTRACT_MAX_URLS=8

# Japan 交付辅助（可选）
JAPAN_DELIVERY_SITES=
JAPAN_DELIVERY_SUMMARY_ONLY=
