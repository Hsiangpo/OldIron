# Japan 新框架
#
# 运行命令：
#   cd Japan
#   python run.py bizmaps all      # 顺序执行 P1→P2→P3
#   python run.py bizmaps list     # 只跑 P1 列表页采集
#   python run.py bizmaps gmap     # 只跑 P2 GMap 官网补全
#   python run.py bizmaps email    # 只跑 P3 邮箱提取
#
# 交付命令：
#   cd ..
#   python product.py Japan day1

# 代理（日本站点需要翻墙）
HTTP_PROXY=http://127.0.0.1:7897
GOOGLE_MAPS_PROXY_URL=socks5h://127.0.0.1:7897

# LLM 配置（Pipeline 3 需要）
LLM_API_KEY=
LLM_BASE_URL=https://gpt-agent.cc/v1
LLM_MODEL=claude-sonnet-4-6
LLM_REASONING_EFFORT=
LLM_API_STYLE=auto
LLM_TIMEOUT_SECONDS=120

# Protocol+LLM 参数
FIRECRAWL_PREFILTER_LIMIT=40
FIRECRAWL_LLM_PICK_COUNT=8
FIRECRAWL_EXTRACT_MAX_URLS=8
