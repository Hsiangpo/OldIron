# Denmark 分片常用命令：
# 1. 主机规划 DNB：python run.py dist plan-dnb --shards 2
# 2. 子机执行 DNB：python run.py dnb --seed-file output/distributed/dnb/shard-001.segments.jsonl --output-dir output/runs/dnb-shard-001
# 3. 主机合并：python run.py dist merge-site dnb --run-dir output/runs/dnb-shard-001 --run-dir output/runs/dnb-shard-002
# 4. 主机交付：cd .. && python product.py Denmark dayN
# Virk 单机命令：python run.py virk --max-companies 100 --output-dir output/virk
# Proff 单机命令：python run.py proff --query ApS --max-pages-per-query 5 --search-workers 16 --gmap-workers 16 --firecrawl-workers 64 --output-dir output/proff
# Proff 默认会自动拉起并关闭它需要的 Go 后端，不需要额外敲启动命令
# Proff 不传 --query 时，默认走行业目录 + 地理 API 深分段的极限覆盖模式

SNOV_CLIENT_ID=
SNOV_CLIENT_SECRET=
