# Denmark 新框架当前只启用 Proff 主线
#
# 运行命令：
#   cd Denmark
#   python run.py proff
#   python run.py proff --query ApS --max-pages-per-query 5 --search-workers 16 --gmap-workers 16 --firecrawl-workers 64
#
# 交付命令：
#   cd ..
#   python product.py Denmark day1

PROFF_PROXY_URL=http://127.0.0.1:7897
GOOGLE_MAPS_PROXY_URL=socks5h://127.0.0.1:7897

MYIP_ENABLED=0
MYIP_PROXY_URL=http://127.0.0.1:17897

FIRECRAWL_KEYS=
FIRECRAWL_KEYS_FILE=output/firecrawl_keys.txt
FIRECRAWL_KEY_POOL_DB=output/cache/firecrawl_keys.db
FIRECRAWL_BASE_URL=https://api.firecrawl.dev/v2/
FIRECRAWL_TIMEOUT_SECONDS=45
FIRECRAWL_MAX_RETRIES=2
FIRECRAWL_KEY_PER_LIMIT=2
FIRECRAWL_KEY_WAIT_SECONDS=20
FIRECRAWL_KEY_COOLDOWN_SECONDS=90
FIRECRAWL_KEY_FAILURE_THRESHOLD=5
FIRECRAWL_PREFILTER_LIMIT=40
FIRECRAWL_LLM_PICK_COUNT=8
FIRECRAWL_EXTRACT_MAX_URLS=8

LLM_API_KEY=
# 注意：以下四项不要照抄历史示例，必须按当前批准的 provider 填写
LLM_BASE_URL=
LLM_MODEL=
LLM_REASONING_EFFORT=
LLM_API_STYLE=auto
LLM_TIMEOUT_SECONDS=120

PROFF_BASE_URL=https://www.proff.dk/branches%C3%B8g
PROFF_TIMEOUT_SECONDS=30
PROFF_MIN_INTERVAL_SECONDS=0.2
PROFF_QUEUE_POLL_INTERVAL=1
PROFF_STALE_RUNNING_REQUEUE_SECONDS=900
PROFF_MAX_TASK_RETRIES=5
PROFF_RETRY_BACKOFF_CAP_SECONDS=120
PROFF_GMAP_MAX_RETRIES=3
PROFF_FIRECRAWL_TASK_MAX_RETRIES=5
PROFF_MAX_RESULTS_PER_SEGMENT=10000
PROFF_USE_GO_GMAP_BACKEND=1
PROFF_USE_GO_FIRECRAWL_BACKEND=0

GMAP_SERVICE_URL=http://127.0.0.1:8082
FIRECRAWL_SERVICE_URL=http://127.0.0.1:8081
