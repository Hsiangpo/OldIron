# ==========================================
# VersatileBackend 环境变量全局配置
# ==========================================
# 注意：此文件为通用后端提供鉴权依赖，请勿将其提交入版本控制。
# 复制此文件为 .env 并填入真实值。

# ----------------- Snov 配置 ----------------
# 支持多账号轮询策略，避免单一额度跑尽
# Snov 账号 1
SNOV_CLIENT_ID=your_client_id_here
SNOV_CLIENT_SECRET=your_client_secret_here

# Snov 账号 2
SNOV_CLIENT_ID_2=your_client_id_2_here
SNOV_CLIENT_SECRET_2=your_client_secret_2_here

# 若有更多账号，可按 SNOV_CLIENT_ID_3 等格式继续添加


# --------------- Firecrawl 配置 -------------
# 用于公司官网爬取、邮箱寻找、大规模并行抽取
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
# 若支持轮询，同样可以通过添加后缀来扩展池子 
# FIRECRAWL_API_KEY_2=your_second_key_here


# ----------------- LLM 配置 -----------------
# 大型语言模型（用于网页候选理解、清洗提取规则等）
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://api.yourprovider.com/v1
LLM_MODEL=gpt-4o-mini
LLM_REASONING_EFFORT=medium
LLM_TIMEOUT_SECONDS=120


# ----------------- 代理与系统配置 ---------------
# (按 AGENTS.md 规范建议，非直连机器常配合代理端口 7897)
PROXY_URL=http://127.0.0.1:7897
HTTP_PORT=8080

# ----------------- MyIP 本地轮询代理 ---------------
# 注意：不是所有站点都要走 MyIP，按站点策略决定是否开启。
MYIP_ENABLED=false
# MyIP 服务监听地址
MYIP_SERVICE_ADDR=:17897
# 轮询策略：host-hash（同域名尽量固定同出口） / round-robin（纯轮询）
MYIP_STRATEGY=host-hash
MYIP_CONNECT_TIMEOUT_SECONDS=15
MYIP_IDLE_TIMEOUT_SECONDS=120
MYIP_COOLDOWN_SECONDS=30
MYIP_MAX_COOLDOWN_SECONDS=300
# 上游代理列表，支持逗号 / 分号 / 换行分隔
# 示例：
# MYIP_UPSTREAMS=http://127.0.0.1:7897;http://user:pass@38.244.50.60:31001
MYIP_UPSTREAMS=
# 也可以改为从文件读取，一行一个上游代理 URL
MYIP_UPSTREAMS_FILE=
# 当站点明确启用 MyIP 时，统一走这个本地入口
MYIP_PROXY_URL=http://127.0.0.1:17897
