# England 分片常用命令：
# 1. 主机规划 CH：python run.py dist plan-ch --shards 2
# 2. 主机规划 DNB：python run.py dist plan-dnb --shards 2
# 3. 子机执行 CH：python run.py companies-house --input-file output/distributed/ch/shard-001.txt --output-dir output/runs/ch-shard-001
# 4. 子机执行 DNB：python run.py dnb --seed-file output/distributed/dnb/shard-001.segments.jsonl --output-dir output/runs/dnb-shard-001
# 5. 主机合并：python run.py dist merge-site companies-house --run-dir output/runs/ch-shard-001
# 6. 主机交付：python product.py dayN

SNOV_CLIENT_ID=
SNOV_CLIENT_SECRET=
DNB_CHROME_DEBUG_URL=http://127.0.0.1:9222
DNB_COOKIE_HEADER=
DNB_PROXY_URL=socks5h://127.0.0.1:7897
GOOGLE_MAPS_PROXY_URL=socks5h://127.0.0.1:7897
FIRECRAWL_KEYS=
FIRECRAWL_KEYS_FILE=output/firecrawl_keys.txt
FIRECRAWL_KEY_POOL_DB=output/cache/firecrawl_keys.db
FIRECRAWL_BASE_URL=https://api.firecrawl.dev/v2/
FIRECRAWL_TIMEOUT_SECONDS=45
FIRECRAWL_MAX_RETRIES=2
FIRECRAWL_KEY_PER_LIMIT=2
FIRECRAWL_KEY_WAIT_SECONDS=20
FIRECRAWL_KEY_COOLDOWN_SECONDS=90
FIRECRAWL_KEY_FAILURE_THRESHOLD=5
FIRECRAWL_PREFILTER_LIMIT=24
FIRECRAWL_LLM_PICK_COUNT=12
FIRECRAWL_EXTRACT_MAX_URLS=10
LLM_API_KEY=
LLM_BASE_URL=https://api.gpteamservices.com/v1
LLM_MODEL=gpt-5.1-codex-mini
LLM_REASONING_EFFORT=medium
LLM_TIMEOUT_SECONDS=120
